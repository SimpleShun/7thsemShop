from flaskext.mysql import MySQL
import pymysql
import os


import click
from flask import current_app, g



def get_db():
    if db not in g:
        g.db = MySQL(
            current_app,
            #host=os.getenv("db_host"),
            user=os.getenv("db_user"),
            password=os.getenv("db_password"),
            db=os.getenv("db_name"),
            autocommit=True,
            cursorclass=pymysql.cursors.DictCursor)
    return g.db

def close_db(e=None):
    db = g.pop("db",None)
    if db is not None:
        db.close()

